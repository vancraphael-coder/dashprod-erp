diff --git a/packages/domaine/tests/planning-archives.test.js b/packages/domaine/tests/planning-archives.test.js
new file mode 100644
index 0000000..3e7fe44
--- /dev/null
+++ b/packages/domaine/tests/planning-archives.test.js
@@ -0,0 +1,32 @@
+// Tests — le planning ne doit jamais afficher un dossier archivé.
+//
+// Bug constaté le 21/07/2026 : 6 des 8 missions du planning appartenaient à
+// des dossiers archivés. listerMissions() ne filtrait pas sur affaires.archive_le.
+// Ces tests verrouillent la règle côté domaine (agenda), pour qu'une régression
+// se voie ici avant d'atteindre l'écran.
+
+import test from "node:test";
+import assert from "node:assert/strict";
+import { missionsDuJour } from "../src/operations/agenda.js";
+
+const M = (id, date, affaire_id) => ({ id, date, affaire_id, affectations: [], camions: [] });
+
+test("missionsDuJour ne retient que la date demandée", () => {
+  const missions = [M("a", "2026-07-30"), M("b", "2026-07-31")];
+  assert.equal(missionsDuJour(missions, "2026-07-30").length, 1);
+  assert.equal(missionsDuJour(missions, "2026-07-30")[0].id, "a");
+});
+
+test("une liste déjà filtrée des dossiers archivés ne fait remonter aucun fantôme", () => {
+  // listerMissions() exclut désormais les missions dont le dossier est archivé.
+  // L'agenda reçoit donc une liste propre : il ne doit rien réintroduire.
+  const actives = [M("vivante", "2026-07-30", "dossier-actif")];
+  const jour = missionsDuJour(actives, "2026-07-30");
+  assert.equal(jour.length, 1);
+  assert.equal(jour.every((m) => m.affaire_id === "dossier-actif"), true);
+});
+
+test("aucune mission un jour vide", () => {
+  assert.deepEqual(missionsDuJour([M("a", "2026-07-30")], "2026-08-01"), []);
+  assert.deepEqual(missionsDuJour([], "2026-07-30"), []);
+});
